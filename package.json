{
  "name": "@goto-lab/pufu-editor",
  "version": "0.9.13",
  "description": "Web editor component for Project score (Pufu).",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:goto-lab/pufu-editor.git"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run clean && tsc && pnpm run copy && pnpm run build:css",
    "build:css": "pnpm exec postcss src/index.css -o dist/index.css",
    "clean": "rimraf ./dist",
    "copy": "copyfiles -u 1 src/**/*.html src/*.css src/**/*.css dist/",
    "model-ti": "pnpm exec ts-interface-builder src/lib/models.ts",
    "storybook": "storybook dev -p 6006",
    "storybook-test": "test-storybook",
    "storybook-test-coverage": "pnpm run storybook-test -- --coverage && pnpm run storybook-coverage-report && pnpm run storybook-coverage-server",
    "storybook-coverage-report": "pnpm exec nyc report --reporter=lcov -t coverage/storybook --report-dir coverage/storybook",
    "storybook-coverage-server": "pnpm exec http-server coverage/storybook/lcov-report/",
    "storybook-build": "storybook build && node .storybook/update-title.mjs",
    "storybook-server": "pnpm exec http-server storybook-static --port 6006 --silent",
    "storybook-test-waiton": "pnpm exec wait-on tcp:127.0.0.1:6006 && pnpm run storybook-test",
    "storybook-build-test": "pnpm exec concurrently -k -s first -n \"SB,TEST\" \"pnpm run storybook-server\" \"pnpm run storybook-test-waiton\"",
    "lint": "eslint src",
    "fix:lint": "eslint src --fix"
  },
  "author": "Dyson Yamashita <oss@haluworks.com>",
  "homepage": "https://github.com/goto-lab/pufu-editor",
  "bugs": "https://github.com/goto-lab/pufu-editor/issues",
  "keywords": [
    "project management",
    "project score",
    "pufu",
    "editor"
  ],
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@babel/preset-react": "^7.24.1",
    "@chromatic-com/storybook": "^1.2.25",
    "@storybook/addon-coverage": "^1.0.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/addon-onboarding": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/manager-api": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@storybook/test-runner": "^0.22.1",
    "@storybook/theming": "^8.6.18",
    "@types/css-modules": "^1.0.5",
    "@types/dom-to-image": "^2.6.7",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/sortablejs": "^1.15.8",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "autoprefixer": "^10.4.17",
    "chromatic": "^11.3.0",
    "concurrently": "^8.2.2",
    "copyfiles": "^2.4.1",
    "dom-to-image": "^2.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-storybook": "^0.8.0",
    "eslint-plugin-tailwindcss": "^3.15.0",
    "html-to-image": "^1.11.13",
    "http-server": "^14.1.1",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "leader-line-new": "^1.1.9",
    "loglevel": "^1.9.2",
    "playwright": "^1.49.1",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.12",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^14.1.3",
    "react-icons": "^5.6.0",
    "react-sortablejs": "^6.1.4",
    "react-textarea-autosize": "^8.5.9",
    "rimraf": "^5.0.5",
    "short-uuid": "^4.2.2",
    "sortablejs": "^1.15.7",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.15",
    "ts-interface-builder": "^0.3.3",
    "ts-interface-checker": "^1.0.2",
    "typescript": "^5.3.3",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0",
    "zustand": "^4.5.7"
  },
  "peerDependencies": {
    "@types/dom-to-image": "^2.6.7",
    "dom-to-image": "^2.6.0",
    "html-to-image": "^1.11.11",
    "i18next": "^23.10.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "leader-line-new": "^1.1.9",
    "loglevel": "^1.9.1",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "react-i18next": "^14.1.0",
    "react-icons": "^5.0.1",
    "react-sortablejs": "^6.1.4",
    "react-textarea-autosize": "^8.5.9",
    "short-uuid": "^4.2.2",
    "sortablejs": "^1.15.2",
    "ts-interface-checker": "^1.0.2",
    "zustand": "^4.5.2"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}
